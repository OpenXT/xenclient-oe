From: Tamas K Lengyel <tamas@tklengyel.com>
Date: Sun, 4 Feb 2018 11:49:09 -0700
Subject: [PATCH 1/3] Hardcode openxt.cfg as EFI config file

---
 xen/common/efi/boot.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

--- a/xen/common/efi/boot.c
+++ b/xen/common/efi/boot.c
@@ -1393,7 +1393,8 @@ void EFIAPI __init noreturn efi_start(EF
     EFI_LOADED_IMAGE *loaded_image;
     EFI_STATUS status;
     unsigned int i;
-    CHAR16 *file_name, *cfg_file_name = NULL, *options = NULL;
+    static CHAR16 __initdata str_openxt[] = L"openxt.cfg";
+    CHAR16 *file_name, *cfg_file_name = str_openxt, *options = NULL;
     UINTN gop_mode = ~0;
     EFI_GRAPHICS_OUTPUT_PROTOCOL *gop = NULL;
     union string section = { NULL }, name;
