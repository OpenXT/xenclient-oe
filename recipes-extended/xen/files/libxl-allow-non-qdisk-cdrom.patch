################################################################################
SHORT DESCRIPTION:
################################################################################
Allow non-qdisk CDROM backends in libxl.

################################################################################
LONG DESCRIPTION:
################################################################################
Upstream libxl forces Qdisk as the backend for CD-Rom devices when using
a device model; this is incorrect for OpenXT.

This patch is needed for ATAPI passthrough and to unblock start of guest VMs.

################################################################################
CHANGELOG
################################################################################

################################################################################
REMOVAL
################################################################################

################################################################################
UPSTREAM PLAN
################################################################################

################################################################################
INTERNAL DEPENDENCIES
################################################################################

################################################################################
PATCHES
################################################################################
--- a/tools/libs/light/libxl_disk.c
+++ b/tools/libs/light/libxl_disk.c
@@ -163,19 +163,6 @@ static int libxl__device_disk_setdefault
         return ERROR_FAIL;
     }

-    /* Only allow Qdisk or Phy for CDROM devices. */
-    if (disk->is_cdrom != 0 &&
-        libxl__domain_type(gc, domid) == LIBXL_DOMAIN_TYPE_HVM) {
-        if (disk->backend == LIBXL_DISK_BACKEND_UNKNOWN)
-            disk->backend = LIBXL_DISK_BACKEND_QDISK;
-
-        if (!(disk->backend == LIBXL_DISK_BACKEND_QDISK ||
-              disk->backend == LIBXL_DISK_BACKEND_PHY)) {
-            LOGD(ERROR, domid,
